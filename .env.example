# ───────────────────────────────────────────────────────────────
# A.D.A.M. — environment variables
# Copy to .env.local for dev. NEVER commit .env.local.
# ───────────────────────────────────────────────────────────────

# Anthropic SDK — used by all agents (server-side only)
ANTHROPIC_API_KEY=sk-ant-...

# Finnhub — market data PRIMARY provider (sesión 6d, AV eliminado)
# Free tier: 60 req/min — sirve quote realtime, profile, fundamentals, news.
# Sin key, el sistema sigue funcionando con Yahoo /v8/chart (quote+candles)
# pero pierdes fundamentals y news (Yahoo no las expone estable en free).
# Signup: https://finnhub.io/register
FINNHUB_API_KEY=

# Supabase — DB + Auth (Sprint 2)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — cache + rate limiting (recomendado desde Sprint 1)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry — observability (ACTIVO, no Sprint 3)
# Sin DSN, Sentry queda no-op silencioso. Con DSN, los errores se reportan
# (con filtros de ruido conocido en instrumentation.ts beforeSend).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Cron secret — protege /api/cmt/scan (Sprint 2)
CRON_SECRET=

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
