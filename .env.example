# ───────────────────────────────────────────────────────────────
# A.D.A.M. — environment variables
# Copy to .env.local for dev. NEVER commit .env.local.
# ───────────────────────────────────────────────────────────────

# Anthropic SDK — used by all agents (server-side only)
ANTHROPIC_API_KEY=sk-ant-...

# Alpha Vantage — market data (quotes, fundamentals, news+sentiment, OHLCV)
# Free tier: 25 req/day, 5/min — el caché Upstash es CRÍTICO con este proveedor.
# Signup: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Supabase — DB + Auth (Sprint 2)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — cache + rate limiting (recomendado desde Sprint 1)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry (Sprint 3)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Cron secret — protege /api/cmt/scan (Sprint 2)
CRON_SECRET=

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
